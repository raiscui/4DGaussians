# 说明:
# - `.envrc` 会被提交到仓库,因此绝不能写入任何密钥.
# - 私密信息请写到 `.envrc.private`(已在 `.gitignore` 中忽略).
# - 启用方式: 安装并启用 direnv 后执行 `direnv allow`.

# -----------------------------------------------------------------------------
# 1) 代理(可选)
# -----------------------------------------------------------------------------
# 默认不启用代理.
# 如果你需要走本地代理,建议在 `.envrc.private` 里打开开关:
#
#   export USE_LOCAL_PROXY=1
#
# 然后按需覆盖下面两个默认地址即可.
export USE_LOCAL_PROXY="${USE_LOCAL_PROXY:-0}"
export LOCAL_PROXY_HTTP="${LOCAL_PROXY_HTTP:-http://127.0.0.1:7897}"
export LOCAL_PROXY_SOCKS5="${LOCAL_PROXY_SOCKS5:-socks5://127.0.0.1:7897}"

if [ "${USE_LOCAL_PROXY}" = "1" ]; then
  export https_proxy="${https_proxy:-$LOCAL_PROXY_HTTP}"
  export http_proxy="${http_proxy:-$LOCAL_PROXY_HTTP}"
  export all_proxy="${all_proxy:-$LOCAL_PROXY_SOCKS5}"

  export HTTPS_PROXY="${HTTPS_PROXY:-$https_proxy}"
  export HTTP_PROXY="${HTTP_PROXY:-$http_proxy}"
  export ALL_PROXY="${ALL_PROXY:-$all_proxy}"
fi

# -----------------------------------------------------------------------------
# 2) 加载私密变量(如果存在)
# -----------------------------------------------------------------------------
if [ -f ".envrc.private" ]; then
  # 说明: `.envrc.private` 可以包含 `export GITHUB_TOKEN=...` 等敏感内容.
  #       该文件被 `.gitignore` 忽略,不会被提交到远端.
  source_env ".envrc.private"
fi

# -----------------------------------------------------------------------------
# 3) GitHub https push 非交互认证(可选)
# -----------------------------------------------------------------------------
# 使用方法:
# - 在 `.envrc.private` 写入:
#     export GITHUB_USERNAME=raiscui
#     export GITHUB_TOKEN=github_pat_xxx
# - 然后执行 `direnv allow` 加载环境.
#
# 注意: 不要把 token 写进 `.envrc`,只放到 `.envrc.private`.
export GITHUB_USERNAME="${GITHUB_USERNAME:-raiscui}"
export GITHUB_TOKEN="${GITHUB_TOKEN:-}"

if [ -n "${GITHUB_USERNAME}" ] && [ -n "${GITHUB_TOKEN}" ]; then
  export GIT_TERMINAL_PROMPT=0
  export GIT_ASKPASS="$PWD/.direnv/git-askpass.sh"

  # 生成 askpass 脚本.
  # - 文件写在 `.direnv/` 下并已被 `.gitignore` 忽略.
  # - 脚本只回显环境变量,不会把 token 写入仓库文件.
  mkdir -p "$PWD/.direnv"
  if [ ! -f "$GIT_ASKPASS" ]; then
    cat > "$GIT_ASKPASS" <<'SH'
#!/bin/sh

prompt="$1"
case "$prompt" in
  *Username*)
    echo "${GITHUB_USERNAME}"
    ;;
  *Password*)
    echo "${GITHUB_TOKEN}"
    ;;
  *)
    echo ""
    ;;
esac
SH
    chmod +x "$GIT_ASKPASS"
  fi
fi

# -----------------------------------------------------------------------------
# 4) uv 下载超时(可选)
# -----------------------------------------------------------------------------
export UV_HTTP_TIMEOUT="${UV_HTTP_TIMEOUT:-600}"
